generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ENUMS

enum Role {
  USER
  PROFESSIONAL
  ADMIN
}

enum ServiceMode {
  REMOTE
  ONSITE
  BOTH
}

enum RequestStatus {
  OPEN
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum BookingStatus {
  PENDING
  ACCEPTED
  STARTED
  COMPLETED
  CANCELLED
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum PostStatus {
  OPEN
  SOLVED
  CLOSED
}

enum NotificationType {
  BOOKING
  MESSAGE
  COMMENT
  REPLY
  LIKE
  FOLLOW
  REVIEW
  SYSTEM
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
  ACTION_TAKEN
}

// USER (Auth + Profile)

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  phone        String?  @unique
  password     String
  avatar       String?
  role         Role     @default(USER)
  refreshToken String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile             Profile?
  professionalProfile ProfessionalProfile?
  verification        Verification?

  serviceRequests ServiceRequest[]
  bookings        Booking[] @relation("BookingUser")
  reviews         Review[]  @relation("ReviewUser")

  posts          ProblemPost[]
  comments       Comment[]
  commentReplies CommentReply[]
  postLikes      PostLike[]
  savedPosts     SavedPost[]
  reportsFiled   Report[]      @relation("Reporter")

  directParticipants DirectParticipant[]
  directMessages      DirectMessage[]

  groupMemberships GroupMember[]
  groupMessages    GroupMessage[]
  ownedGroups      Group[] @relation("GroupOwner")

  followers Follow[] @relation("Follower")
  following Follow[] @relation("Following")

  notifications Notification[]

  @@map("users")
}

model Profile {
  id        String  @id @default(cuid())
  userId    String  @unique
  address   String?
  city      String?
  state     String?
  pincode   String?
  latitude  Float?
  longitude Float?

  user User @relation(fields: [userId], references: [id])

  @@map("profiles")
}

// VERIFICATION (shared by all users, only professionals fill certificate)

model Verification {
  id               String              @id @default(cuid())
  userId           String              @unique
  documentType     String? // aadhaar | passport | driving_license
  documentNumber   String?
  documentFrontUrl String?
  documentBackUrl  String?
  selfieUrl        String?
  certificateUrl   String?
  certificateName  String?
  status           VerificationStatus  @default(PENDING)
  verifiedBy       String? // admin userId
  verifiedAt       DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([status])
  @@map("verifications")
}

// PROFESSIONAL

model ProfessionalProfile {
  id              String      @id @default(cuid())
  userId          String      @unique
  headline        String?
  description     String?     @db.Text
  experienceYears Int         @default(0)
  hourlyRate      Float?
  serviceMode     ServiceMode @default(BOTH)
  workingRadiusKm Int         @default(10)
  averageRating   Float       @default(0)
  reviewCount     Int         @default(0)
  completedJobs   Int         @default(0)
  totalJobs       Int         @default(0)
  isAvailable     Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user       User                    @relation(fields: [userId], references: [id])
  categories ProfessionalCategory[]
  bookings   Booking[]               @relation("BookingProfessional")
  reviews    Review[]                @relation("ReviewProfessional")

  @@index([isAvailable])
  @@map("professional_profiles")
}

model Category {
  id   String  @id @default(cuid())
  name String  @unique
  slug String  @unique
  icon String?

  professionals ProfessionalCategory[]
  requests      ServiceRequest[]
  posts         ProblemPost[]

  @@map("categories")
}

model ProfessionalCategory {
  id                    String @id @default(cuid())
  professionalProfileId String
  categoryId            String

  professionalProfile ProfessionalProfile @relation(fields: [professionalProfileId], references: [id])
  category            Category            @relation(fields: [categoryId], references: [id])

  @@unique([professionalProfileId, categoryId])
  @@map("professional_categories")
}

// SERVICE REQUEST / BOOKING

model ServiceRequest {
  id          String        @id @default(cuid())
  requesterId String
  categoryId  String
  title       String
  description String        @db.Text
  images      String[]
  mode        ServiceMode   @default(BOTH)
  budget      Float?
  address     String?
  city        String?
  latitude    Float?
  longitude   Float?
  status      RequestStatus @default(OPEN)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  requester User      @relation(fields: [requesterId], references: [id])
  category  Category  @relation(fields: [categoryId], references: [id])
  bookings  Booking[]

  @@index([categoryId])
  @@index([requesterId])
  @@index([status])
  @@map("service_requests")
}

model Booking {
  id               String        @id @default(cuid())
  serviceRequestId String
  userId           String
  professionalId   String
  status           BookingStatus @default(PENDING)
  amount           Float?
  scheduledAt      DateTime?
  acceptedAt       DateTime?
  startedAt        DateTime?
  completedAt      DateTime?
  cancelReason     String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  serviceRequest ServiceRequest      @relation(fields: [serviceRequestId], references: [id])
  user           User                @relation("BookingUser", fields: [userId], references: [id])
  professional   ProfessionalProfile @relation("BookingProfessional", fields: [professionalId], references: [id])
  review         Review?

  @@index([userId])
  @@index([professionalId])
  @@index([serviceRequestId])
  @@map("bookings")
}

model Review {
  id             String   @id @default(cuid())
  bookingId      String   @unique
  userId         String
  professionalId String
  rating         Int
  comment        String?  @db.Text
  images         String[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  booking      Booking             @relation(fields: [bookingId], references: [id])
  user         User                @relation("ReviewUser", fields: [userId], references: [id])
  professional ProfessionalProfile @relation("ReviewProfessional", fields: [professionalId], references: [id])

  @@map("reviews")
}

// COMMUNITY (Home feed / Posts)

model ProblemPost {
  id         String     @id @default(cuid())
  authorId   String
  categoryId String?
  title      String
  content    String     @db.Text
  images     String[]
  status     PostStatus @default(OPEN)
  viewCount  Int        @default(0)
  city       String?
  latitude   Float?
  longitude  Float?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  // likeCount / commentCount NOT stored. Use Prisma `_count`.

  author   User        @relation(fields: [authorId], references: [id])
  category Category?   @relation(fields: [categoryId], references: [id])
  comments Comment[]
  likes    PostLike[]
  savedBy  SavedPost[]
  reports  Report[]

  @@index([authorId])
  @@index([categoryId])
  @@index([status])
  @@index([createdAt])
  @@map("problem_posts")
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  content   String   @db.Text
  createdAt DateTime @default(now())

  post    ProblemPost    @relation(fields: [postId], references: [id])
  author  User           @relation(fields: [authorId], references: [id])
  replies CommentReply[]
  reports Report[]

  @@index([postId])
  @@index([authorId])
  @@map("comments")
}

model CommentReply {
  id        String   @id @default(cuid())
  commentId String
  authorId  String
  content   String   @db.Text
  createdAt DateTime @default(now())

  comment Comment @relation(fields: [commentId], references: [id])
  author  User    @relation(fields: [authorId], references: [id])

  @@index([commentId])
  @@index([authorId])
  @@map("comment_replies")
}

model PostLike {
  id     String @id @default(cuid())
  postId String
  userId String

  post ProblemPost @relation(fields: [postId], references: [id])
  user User        @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
  @@map("post_likes")
}

model SavedPost {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User        @relation(fields: [userId], references: [id])
  post ProblemPost @relation(fields: [postId], references: [id])

  @@unique([userId, postId])
  @@map("saved_posts")
}

model Report {
  id         String       @id @default(cuid())
  reporterId String
  postId     String?
  commentId  String?
  reason     String
  status     ReportStatus @default(PENDING)
  createdAt  DateTime     @default(now())
  reviewedAt DateTime?

  reporter User         @relation("Reporter", fields: [reporterId], references: [id])
  post     ProblemPost? @relation(fields: [postId], references: [id])
  comment  Comment?     @relation(fields: [commentId], references: [id])

  @@index([status])
  @@map("reports")
}

// DIRECT CHAT (1:1 — REST + polling)

model DirectConversation {
  id            String    @id @default(cuid())
  lastMessageAt DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())

  participants DirectParticipant[]
  messages     DirectMessage[]

  @@map("direct_conversations")
}

model DirectParticipant {
  id             String @id @default(cuid())
  conversationId String
  userId         String

  conversation DirectConversation @relation(fields: [conversationId], references: [id])
  user         User               @relation(fields: [userId], references: [id])

  @@unique([conversationId, userId])
  @@map("direct_participants")
}

model DirectMessage {
  id             String    @id @default(cuid())
  conversationId String
  senderId       String
  content        String?   @db.Text
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  conversation DirectConversation @relation(fields: [conversationId], references: [id])
  sender       User               @relation(fields: [senderId], references: [id])

  @@index([conversationId])
  @@map("direct_messages")
}

// GROUP CHAT

model Group {
  id            String    @id @default(cuid())
  name          String
  description   String?
  image         String?
  ownerId       String
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  owner    User           @relation("GroupOwner", fields: [ownerId], references: [id])
  members  GroupMember[]
  messages GroupMessage[]

  @@index([ownerId])
  @@map("groups")
}

model GroupMember {
  id       String   @id @default(cuid())
  groupId  String
  userId   String
  isAdmin  Boolean  @default(false)
  joinedAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
  @@map("group_members")
}

model GroupMessage {
  id        String   @id @default(cuid())
  groupId   String
  senderId  String
  content   String?  @db.Text
  createdAt DateTime @default(now())

  group  Group @relation(fields: [groupId], references: [id])
  sender User  @relation(fields: [senderId], references: [id])

  @@index([groupId])
  @@map("group_messages")
}

// FOLLOW

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Follower", fields: [followerId], references: [id])
  following User @relation("Following", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
  @@map("follows")
}

// NOTIFICATIONS

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?
  link      String? // e.g. deep link to post/booking/chat
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}
